{
  "name": "furikaeri-mcp",
  "version": "0.1.0",
  "description": "個人活動データを横断的に取得するMCPサーバー",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=prisma/yarukoto/schema.prisma && prisma generate --schema=prisma/peak-log/schema.prisma"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@prisma/client": "^6.5.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "googleapis": "^148.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.23.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
