# Yarukoto DB
YARUKOTO_DATABASE_URL=postgresql://...

# Peak Log DB
PEAK_LOG_DATABASE_URL=postgresql://...

# 日記アプリ DB（後日追加）
DIARY_DATABASE_URL=postgresql://...

# Google Calendar API
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# userId（各アプリでの自分の userId）
YARUKOTO_USER_ID=cuid_xxx
PEAK_LOG_USER_ID=cuid_yyy

# GitHub
GITHUB_TOKEN=ghp_...

# Transport（stdio | http、デフォルト: stdio）
TRANSPORT=stdio

# HTTP モード時のポート（Railway は自動設定）
PORT=3000
