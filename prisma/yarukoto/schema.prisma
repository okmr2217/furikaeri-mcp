generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/yarukoto"
}

datasource db {
  provider = "postgresql"
  url      = env("YARUKOTO_DATABASE_URL")
}

enum TaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model Task {
  id           String      @id
  userId       String
  categoryId   String?
  title        String
  memo         String?
  status       TaskStatus
  priority     Priority?
  scheduledAt  DateTime?   @db.Date
  completedAt  DateTime?
  skippedAt    DateTime?
  skipReason   String?
  displayOrder Float
  createdAt    DateTime
  updatedAt    DateTime

  category     Category?   @relation(fields: [categoryId], references: [id])
}

model Category {
  id     String  @id
  userId String
  name   String
  color  String?

  tasks  Task[]
}
